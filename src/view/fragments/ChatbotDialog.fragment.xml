<core:FragmentDefinition
	xmlns:core="sap.ui.core"
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
>
	<Dialog
		id="chatbotDialog"
		title="Plant Assistant Chatbot"
		contentWidth="750px"
		contentHeight="600px"
		resizable="true"
		draggable="true"
		afterClose="onChatbotDialogClose"
	>
		<customHeader>
			<Bar>
				<contentLeft>
					<Image
						src="./css/aloe-vera.png"
						width="2rem"
						height="2rem"
						class="sapUiTinyMarginEnd"
					/>
					<Title text="Plant Assistant" level="H5"/>
				</contentLeft>
				<contentRight>
					<Button
						icon="sap-icon://refresh"
						tooltip="Clear Chat"
						press="onClearChat"
						type="Transparent"
					/>
					<Button
						icon="sap-icon://decline"
						tooltip="Close"
						press="onCloseChatbot"
						type="Transparent"
					/>
				</contentRight>
			</Bar>
		</customHeader>

		<content>
			<VBox class="chatbotContainer">
				<!-- Chat Messages Container -->
				<VBox
					id="chatMessagesContainer"
					class="chatMessagesScrollContainer"
					height="100%"
				>
					<VBox
						id="chatMessagesBox"
						class="chatMessagesBox"
						items="{chatbot>/messages}"
					>
						<customData>
							<core:CustomData key="scrollToBottom" value="true" />
						</customData>
						
						<items>
							<VBox 
								class="chatMessage"
								visible="{= ${chatbot&gt;text} !== '' }"
							>
								<customData>
									<core:CustomData key="role" value="{chatbot>role}" writeToDom="true" />
								</customData>
								<HBox alignItems="Start" class="chatMessageHeader">
									<Avatar
										src="{= ${chatbot>role} === 'user' ? 'sap-icon://customer' : 'sap-icon://marketing-campaign' }"
										displaySize="XS"
										class="chatAvatar"
										backgroundColor="{= ${chatbot>role} === 'user' ? 'Accent6' : 'Accent8' }"
									/>
									<VBox class="chatMessageContent">
										<Text
											text="{= ${chatbot>role} === 'user' ? 'You' : 'Plant Assistant' }"
											class="chatSpeakerLabel"
										/>
										<FormattedText
											htmlText="{chatbot>text}"
											class="chatMessageText"
										/>
										<HBox
											visible="{= ${chatbot>plant_refs} &amp;&amp; ${chatbot>plant_refs}.length > 0 }"
											wrap="Wrap"
											class="sapUiTinyMarginTop"
											items="{path: 'chatbot>plant_refs'}"
										>
											<Button
												text="{= ${chatbot>plant_name} ? ${chatbot>plant_id} + ' ' + ${chatbot>plant_name} : ${chatbot>plant_id} }"
												type="Emphasized"
												class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                                press="onPlantIdButtonPress"/>
										</HBox>
										<Text
											text="{chatbot>timestamp}"
											class="chatMessageTimestamp"
										/>
									</VBox>
								</HBox>
							</VBox>
						</items>
					</VBox>
				</VBox>

				<!-- Typing Indicator -->
				<HBox
					id="typingIndicator"
					visible="{chatbot>/isTyping}"
					class="typingIndicatorContainer"
					alignItems="Center"
				>
					<Avatar
						src="sap-icon://marketing-campaign"
						displaySize="XS"
						backgroundColor="Accent8"
						class="chatAvatar"
					/>
					<HBox class="typingIndicator">
						<core:HTML content="&lt;div class='typing-dot'&gt;&lt;/div&gt;&lt;div class='typing-dot'&gt;&lt;/div&gt;&lt;div class='typing-dot'&gt;&lt;/div&gt;" />
					</HBox>
				</HBox>
			</VBox>
		</content>

		<footer>
			<Toolbar class="chatInputBar">
				<TextArea
					growing="true"
					growingMaxLines="4"
					width="100%"
					value="{chatbot>/currentMessage}"
					placeholder="Ask me about your plants..."
				/>
				<ToolbarSpacer />
				<Button
					icon="sap-icon://paper-plane"
					type="Emphasized"
					press="onSendMessage"
				/>
			</Toolbar>
		</footer>

		<beginButton>
			<Button
				text="Close"
				press="onCloseChatbot"
			/>
		</beginButton>
	</Dialog>
</core:FragmentDefinition>
